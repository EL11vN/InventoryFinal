# Firebase Configuration (Required for Production)
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=inventorymanagement-8be56
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@inventorymanagement-8be56.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----

# Development Settings (Set to false for production)
USE_FIRESTORE_EMULATOR=false
FIRESTORE_EMULATOR_HOST=localhost:8080

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS - Allow your Firebase Hosting domain
CORS_ORIGIN=https://inventorymanagement-8be56.web.app

# JWT Configuration
JWT_SECRET=change_this_to_a_secure_random_string
JWT_EXPIRY=7d
